# Build scratch — everything below is cloned/generated by a publish run and is
# fully reproducible. Nothing here should ever be committed.

# IG Publisher jar (downloaded by _updatePublisher.sh)
input-cache/
publisher.jar

# IGs / templates / registry cloned during a local publish
hl7au/
ig-registry/
ig-history/
fhir-history/

# Assembled site + publisher temp
webroot/
temp/

# Stray local working clones (e.g. working-au-fhir-core/)
working-*/
